# OfferSendly environment variables.
# Copy this file to .env.local for local development and set the same vars in
# your Vercel project settings (Production + Preview).

# Neon Postgres — copy the "pooled" connection string from the Neon dashboard.
DATABASE_URL=postgres://user:password@ep-xxx.us-east-1.aws.neon.tech/offersendly?sslmode=require

# Admin login password (you'll type this into /admin/login).
ADMIN_PASSWORD=replace-me-with-a-strong-passphrase

# 32+ character random string used to sign the admin session cookie.
# Generate with:  openssl rand -hex 32
AUTH_SECRET=replace-me-with-a-32-byte-random-hex-string

# Vercel Blob read/write token. Create a Blob store in your Vercel project,
# then copy the BLOB_READ_WRITE_TOKEN from the store's settings.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxx
