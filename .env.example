# OnlineOnSale environment variables.
# Copy this file to .env.local for local development, and set the same vars
# in your Vercel project settings (Production + Preview).

# ─── Neon Postgres ─────────────────────────────────────────────────────────
# Copy the "pooled" connection string from the Neon dashboard.
DATABASE_URL=postgres://user:password@ep-xxx.us-east-1.aws.neon.tech/onlineonsale?sslmode=require

# ─── Admin login ───────────────────────────────────────────────────────────
# The password you'll type into /admin/login.
ADMIN_PASSWORD=replace-me-with-a-strong-passphrase

# 32+ character random string used to sign the admin session cookie.
# Generate with:  openssl rand -hex 32
AUTH_SECRET=replace-me-with-a-32-byte-random-hex-string

# ─── Cloudflare R2 (image upload) ──────────────────────────────────────────
# R2 free tier: 10 GB storage + unlimited egress bandwidth. Setup:
#   1. Cloudflare dashboard → R2 → Create bucket (name it e.g. "onlineonsale")
#   2. The bucket's Settings tab → Public Access → Allow Access.
#      Cloudflare will give you a URL like https://pub-xxxxx.r2.dev/
#      → that's your R2_PUBLIC_BASE_URL.
#   3. R2 → Manage R2 API Tokens → Create API Token → Object Read & Write,
#      scoped to this bucket → copy the Access Key ID + Secret.
#   4. R2_ACCOUNT_ID is in the URL of the R2 page, or shown on any API
#      token page (e.g. "Use the jurisdiction-specific S3 endpoint" hint).
R2_ACCOUNT_ID=your-32-char-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=onlineonsale
R2_PUBLIC_BASE_URL=https://pub-xxxxx.r2.dev
